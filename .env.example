APP_NAME="Open.ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Argentina/Buenos_Aires
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── PostgreSQL ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=gx_postgres
DB_PORT=5432
DB_DATABASE=gxerp
DB_USERNAME=goxtech
DB_PASSWORD=gxlabs_secret

# ── Redis: Cache + Sesiones + Queue ───────────────────────
# Redis maneja cache de queries pesadas (stock 1000+ art, KPIs inventario)
# y sesiones de usuario para máxima performance
REDIS_HOST=gx_redis
REDIS_PORT=6379
REDIS_PASSWORD=gxredis_secret
REDIS_CLIENT=phpredis

CACHE_STORE=redis
CACHE_PREFIX=gx_erp
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
QUEUE_CONNECTION=redis

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="erp@goxtechlabs.com.ar"
MAIL_FROM_NAME="${APP_NAME}"

# ── AFIP WebServices ───────────────────────────────────────
AFIP_CUIT=
AFIP_CERT=
AFIP_KEY=
AFIP_MODE=homologacion
