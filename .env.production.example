# Variables de Entorno - PRODUCCIÓN
# Copiá este archivo en el Stack de Portainer > "Environment variables"
# NUNCA subas este archivo al repositorio (está en .gitignore)

# ── Aplicación ──────────────────────────────────────────────
APP_NAME="ERP Laravel"
APP_ENV=production
APP_KEY=base64:GENERAR_CON_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://erp.tu-dominio.com

# ── Base de Datos PostgreSQL ─────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=erp_produccion
DB_USERNAME=erp_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_REDIS

# ── Cache, Sesiones, Queue ───────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password-gmail
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=erp@tu-empresa.com
MAIL_FROM_NAME="ERP AFIP"

# ── AFIP WebServices ──────────────────────────────────────────
AFIP_CUIT=20123456789
AFIP_MODE=produccion
# Los certificados van en /opt/erp/certs/ en el host
# y se montan en /var/www/html/storage/afip/ en el contenedor

# ── Docker / Portainer ────────────────────────────────────────
GITHUB_USER=tu-usuario-github
NGINX_PORT=80
DOMAIN=erp.tu-dominio.com
