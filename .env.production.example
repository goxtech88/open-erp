# Variables de Entorno — PRODUCCIÓN Open.ERP
# Copiá estos valores en Portainer → Stack → Environment variables
# NUNCA subas este archivo al repositorio (está en .gitignore)

# ── Aplicación ──────────────────────────────────────────────
APP_NAME="Open.ERP"
APP_ENV=production
APP_KEY=base64:GENERAR_CON_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://erp.goxtechlabs.com.ar

# ── PostgreSQL (stack externo en Proxmox) ────────────────
# Si usás el stack 'postgres' que ya tenés en Portainer:
DB_HOST=gx_postgres         # o la IP interna del contenedor postgres existente
DB_PORT=5432
DB_DATABASE=gxerp
DB_USERNAME=goxtech
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO

# ── Redis (stack externo en Proxmox) ────────────────────
# Si usás el stack 'redis' que ya tenés en Portainer:
REDIS_HOST=gx_redis         # o la IP interna del contenedor redis existente
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIAR_POR_PASSWORD_REDIS
REDIS_CLIENT=phpredis

# ── Cache + Sesiones (redis para performance máxima) ────
# Resuelve: queries lentas con 1000+ artículos y KPIs de inventario
CACHE_STORE=redis
CACHE_PREFIX=gx_erp
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ── Red compartida con postgres/redis externos ───────────
# Nombre de la network del stack postgres en Docker
DATA_NETWORK=postgres_default   # ajustar al nombre real

# ── Nginx / Dominio ──────────────────────────────────────
NGINX_PORT=8080
DOMAIN=erp.goxtechlabs.com.ar

# ── Mail ─────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=erp@goxtechlabs.com.ar
MAIL_PASSWORD=TU_APP_PASSWORD_GMAIL
MAIL_FROM_ADDRESS=erp@goxtechlabs.com.ar

# ── AFIP WebServices ──────────────────────────────────────
AFIP_CUIT=20XXXXXXXXX
AFIP_MODE=produccion
# Los certificados van en /opt/goxtech/erp/certs/ en el host
